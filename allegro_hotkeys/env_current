source $TELENV

### Rats:
funckey F9 "rats show"
funckey SF9 "rats blank"

### Set 0.550 grid:
funckey F10 "define grid; FORM grid non_etch non_etch_x_grids 0.550; FORM grid non_etch non_etch_y_grids 0.550; FORM grid all_etch all_etch_x_grids 0.550; FORM grid all_etch all_etch_y_grids 0.550; FORM grid done; echo Grid = Custom 1 = 0.550mm, such via grid"
### Set 0.1375 grid:
funckey SF10 "define grid; FORM grid non_etch non_etch_x_grids 0.1375; FORM grid non_etch non_etch_y_grids 0.1375; FORM grid all_etch all_etch_x_grids 0.1375; FORM grid all_etch all_etch_y_grids 0.1375; FORM grid done; echo Grid = Custom 2 = 0.1375mm, perfectly aligned tracks :D"

